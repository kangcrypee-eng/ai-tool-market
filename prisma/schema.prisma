generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ToolStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum PostType {
  TOOL_SHARE
  TIP
  QUESTION
  REVIEW
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  bio           String?
  role          Role     @default(USER)
  provider      String?  // kakao, google, etc.
  providerId    String?  // external provider user id
  bankName      String?
  accountNumber String?
  accountHolder String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tools         Tool[]
  payments      Payment[]
  ownerships    UserToolOwnership[]
  posts         Post[]
  comments      Comment[]
  postLikes      PostLike[]
  notifications  Notification[]
  settlements    Settlement[]
  contestEntries ContestEntry[]
  contestVotes   ContestVote[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // LIKE, COMMENT, REVIEW, PAYMENT
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Tool {
  id              String     @id @default(uuid())
  name            String
  description     String
  longDescription String?
  imageUrl        String?
  toolUrl         String?    // 외부 링크
  toolContent     String?    // 텍스트 콘텐츠 (마크다운)
  category        String     @default("general")
  creatorId       String
  oneTimePrice    Int?       // null/0 = 무료, 1+ = 유료
  status          ToolStatus @default(PENDING)
  freeTrialDays   Int        @default(30)
  publishedAt     DateTime   @default(now())
  viewCount       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  creator    User               @relation(fields: [creatorId], references: [id])
  payments   Payment[]
  ownerships UserToolOwnership[]
  posts      Post[]
  comments       Comment[]
  files          ToolFile[]
}

model ToolFile {
  id        String   @id @default(uuid())
  toolId    String
  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String
  createdAt DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  toolId    String?
  type      PostType
  title     String
  body      String
  tags      String[] @default([])
  images    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User       @relation(fields: [authorId], references: [id])
  tool     Tool?      @relation(fields: [toolId], references: [id])
  comments Comment[]
  likes    PostLike[]
}

model PostLike {
  id     String @id @default(uuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  toolId    String?
  postId    String?
  content   String
  rating    Int?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  tool Tool? @relation(fields: [toolId], references: [id])
  post Post? @relation(fields: [postId], references: [id])
}

model Payment {
  id             String   @id @default(uuid())
  userId         String
  toolId         String
  amountTotal    Int
  platformFee    Int      // 20% (PG 포함)
  creatorAmount  Int      // 80%
  tossPaymentKey String?
  tossOrderId    String?
  status         String   @default("PAID") // PAID, REFUNDED
  paidAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tool Tool @relation(fields: [toolId], references: [id])
}

model UserToolOwnership {
  id          String   @id @default(uuid())
  userId      String
  toolId      String
  purchasedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tool Tool @relation(fields: [toolId], references: [id])

  @@unique([userId, toolId])
}

model Settlement {
  id            String    @id @default(uuid())
  creatorId     String
  amount        Int
  status        String    @default("PENDING") // PENDING, APPROVED, COMPLETED, REJECTED
  bankName      String?
  accountNumber String?
  accountHolder String?
  requestedAt   DateTime  @default(now())
  completedAt   DateTime?
  adminNote     String?

  creator User @relation(fields: [creatorId], references: [id])
}

model Contest {
  id          String    @id @default(uuid())
  title       String
  description String
  bannerText  String?
  status      String    @default("UPCOMING") // UPCOMING, ACTIVE, VOTING, ENDED
  startDate   DateTime
  endDate     DateTime
  votingEnd   DateTime?
  resultDate  DateTime?
  prizes      String?
  rules       String?
  createdAt   DateTime  @default(now())

  entries ContestEntry[]
}

model ContestEntry {
  id          String   @id @default(uuid())
  contestId   String
  userId      String
  title       String
  description String
  videoUrl    String?    // YouTube URL (임베드용)
  tryUrl      String?    // 사용해보기 링크 (새 탭)
  images      String[] @default([])
  status      String   @default("SUBMITTED") // SUBMITTED, APPROVED, WINNER_1, WINNER_2, WINNER_3
  createdAt   DateTime @default(now())

  contest Contest      @relation(fields: [contestId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  votes   ContestVote[]
}

model ContestVote {
  id        String   @id @default(uuid())
  userId    String
  entryId   String
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id])
  entry ContestEntry @relation(fields: [entryId], references: [id])
}
